<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_bg">

    <!-- ═══ 标题行 ═══ -->
    <LinearLayout
        android:id="@+id/top_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DeepSeek"
            android:textSize="12sp"
            android:textColor="@color/sub_text"
            android:textStyle="bold"
            android:lines="1" />

        <TextView
            android:id="@+id/tv_refresh_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textSize="12sp"
            android:textColor="@color/sub_text"
            android:lines="1" />

    </LinearLayout>

    <!-- 余额 -->
    <TextView
        android:id="@+id/tv_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⟳ 加载中..."
        android:textSize="22sp"
        android:textColor="@color/balance_text"
        android:textStyle="bold"
        android:lines="1"
        android:ellipsize="end" />

    <!-- 今日 + 本月 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today ¥--"
            android:textSize="11sp"
            android:textColor="@color/label_text"
            android:lines="1" />

        <TextView
            android:id="@+id/tv_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  Month ¥--"
            android:textSize="11sp"
            android:textColor="@color/label_text"
            android:layout_marginStart="8dp"
            android:lines="1" />

    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="4dp" />

    <!-- ═══ 下半部 ═══ -->
    <LinearLayout
        android:id="@+id/bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_model_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flash ›"
            android:textSize="12sp"
            android:textColor="@color/label_text"
            android:textStyle="bold"
            android:lines="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="1dp">

            <TextView
                android:id="@+id/tv_token"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="11sp"
                android:textColor="@color/balance_text"
                android:textStyle="bold"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:id="@+id/tv_cache_rate"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="11sp"
                android:textColor="@color/cache_text"
                android:textStyle="bold"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:id="@+id/tv_model_cost"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="11sp"
                android:textColor="@color/balance_text"
                android:textStyle="bold"
                android:gravity="center"
                android:lines="1" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Token"
                android:textSize="10sp"
                android:textColor="@color/sub_text"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Cache"
                android:textSize="10sp"
                android:textColor="@color/sub_text"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Cost"
                android:textSize="10sp"
                android:textColor="@color/sub_text"
                android:gravity="center"
                android:lines="1" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
