<?xml version="1.0" encoding="utf-8"?>
<!-- DeepSeek Dashboard Widget Layout (4x2 cells) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <!-- Left column: Balance -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tv_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¥0.00"
            android:textSize="28sp"
            android:textColor="@color/balance_text"
            android:textStyle="bold"
            android:lines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_today_cost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 今日 ¥0"
            android:textSize="11sp"
            android:textColor="@color/label_text"
            android:layout_marginTop="4dp"
            android:lines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕐 --:--"
            android:textSize="10sp"
            android:textColor="@color/sub_text"
            android:layout_marginTop="2dp"
            android:lines="1" />

    </LinearLayout>

    <!-- Vertical divider -->
    <View
        android:id="@+id/widget_divider"
        android:layout_width="1dp"
        android:layout_height="48dp"
        android:background="@color/divider_color"
        android:layout_marginHorizontal="8dp" />

    <!-- Right column: Token + Cache stats -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="start">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_input_tokens"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 输入 --"
                android:textSize="11sp"
                android:textColor="@color/label_text"
                android:lines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_output_tokens"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="· 输出 --"
                android:textSize="11sp"
                android:textColor="@color/label_text"
                android:lines="1"
                android:ellipsize="end"
                android:layout_marginStart="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_cache_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💾 缓存命中 --"
            android:textSize="11sp"
            android:textColor="@color/cache_text"
            android:layout_marginTop="4dp"
            android:lines="1"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
