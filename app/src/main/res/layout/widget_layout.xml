<?xml version="1.0" encoding="utf-8"?>
<!-- 严格遵守规则：无 weight，无 ConstraintLayout，全部 wrap_content -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg">

    <!-- ── 上半区：点此刷新 ── -->
    <LinearLayout
        android:id="@+id/top_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题行：DeepSeek 左，时间右 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:text="DeepSeek"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:lines="1" />

            <TextView
                android:id="@+id/tv_refresh_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:text="--:--"
                android:textSize="12sp"
                android:textColor="#888888"
                android:lines="1" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⟳ 加载中..."
            android:textSize="22sp"
            android:textColor="#1A73E8"
            android:textStyle="bold"
            android:lines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_today"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today ¥--"
                android:textSize="11sp"
                android:textColor="#444444"
                android:lines="1"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Month ¥--"
                android:textSize="11sp"
                android:textColor="#444444"
                android:lines="1"
                android:layout_marginTop="2dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- ── 下半区：点此切换模型 ── -->
    <LinearLayout
        android:id="@+id/bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tv_model_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flash ›"
            android:textSize="12sp"
            android:textColor="#444444"
            android:textStyle="bold"
            android:lines="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_token"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#1A73E8"
                android:textStyle="bold"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:id="@+id/tv_cache_rate"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#0D9B56"
                android:textStyle="bold"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:id="@+id/tv_model_cost"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#1A73E8"
                android:textStyle="bold"
                android:gravity="center"
                android:lines="1" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Token"
                android:textSize="10sp"
                android:textColor="#888888"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Cache"
                android:textSize="10sp"
                android:textColor="#888888"
                android:gravity="center"
                android:lines="1" />

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Cost"
                android:textSize="10sp"
                android:textColor="#888888"
                android:gravity="center"
                android:lines="1" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
