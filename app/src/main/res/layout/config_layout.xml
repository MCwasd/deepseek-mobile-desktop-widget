<?xml version="1.0" encoding="utf-8"?>
<!-- Configuration activity layout — email + password login instead of API Key -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DeepSeek Dashboard"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/balance_text"
            android:layout_marginTop="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="登录 DeepSeek 账号"
            android:textSize="14sp"
            android:textColor="@color/sub_text"
            android:layout_marginTop="8dp" />

        <!-- Email Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DeepSeek 邮箱"
            android:textSize="13sp"
            android:textColor="@color/label_text"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="your@email.com"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="12dp"
            android:autofillHints="emailAddress" />

        <!-- Password Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="密码"
            android:textSize="13sp"
            android:textColor="@color/label_text"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="••••••••"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="12dp"
            android:autofillHints="password" />

        <!-- Status -->
        <TextView
            android:id="@+id/tv_config_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/label_text"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="取消"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"
                style="?android:attr/buttonStyle" />

            <Button
                android:id="@+id/btn_login"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="登录并验证"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                style="?android:attr/buttonStyle" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n💡 说明：\n• 使用 DeepSeek 开放平台账号登录\n• 密码加密存储在手机本地\n• 登录后自动获取访问令牌\n• 令牌过期会自动重新登录\n• 每 30 分钟自动刷新用量数据\n• 点击小组件可手动刷新"
            android:textSize="12sp"
            android:textColor="@color/sub_text"
            android:layout_marginTop="32dp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</ScrollView>
